# Generated at deploy time by ./init-env.sh from AWS SSM Parameter Store.
# Never commit a real .env. This file documents the variables expected.

POSTGRES_DB=orquestio
POSTGRES_USER=orquestio
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=__from_ssm__/orquestio/prod/POSTGRES_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=__from_ssm__/orquestio/prod/REDIS_PASSWORD

API_KEY=__from_ssm__/orquestio/prod/API_KEY
ENCRYPTION_KEY=__from_ssm__/orquestio/prod/ENCRYPTION_KEY
CLOUDFLARE_API_TOKEN=__from_ssm__/orquestio/prod/CLOUDFLARE_API_TOKEN
